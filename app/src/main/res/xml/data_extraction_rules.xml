<?xml version="1.0" encoding="utf-8"?>
<!--
  SECURITY hardening: this app holds live bank credentials + the backend bearer
  token (encrypted under a non-exportable Android Keystore key). Backing up the
  app's private storage would ship the credential ciphertext and connection
  metadata off-device, so we disable BOTH cloud backup and device-to-device
  transfer entirely. Combined with android:allowBackup="false" in the manifest,
  nothing under the app's data dir is ever extracted (Android 12+ uses these
  rules; older versions honour allowBackup/fullBackupContent="false").
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
