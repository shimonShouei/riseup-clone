# Copy to `.env` and fill in real values. NEVER commit `.env` (see .gitignore).
# This file contains PLACEHOLDERS ONLY — no real secrets.

# --- Bank Discount login ---
# Your Discount online-banking credentials. Held in memory only for one run;
# never logged, never written to disk.
DISCOUNT_ID=
DISCOUNT_PASSWORD=
DISCOUNT_NUM=

# --- Optional ---
# How far back to fetch, as an ISO date (YYYY-MM-DD). Defaults to ~12 months ago.
START_DATE=

# Where to write the CSV statement. Defaults to ./discount-statement.csv
OUT=

# --- Upload mode (cloud file drop) ---
# Used by `npm run upload`, which scrapes then pushes the CSV to your own cloud
# storage so the phone can fetch it from ANY network. Only transactions are
# uploaded — credentials are NEVER uploaded, printed, or logged.
#
# Dropbox access token for a Dropbox app with the files.content.write and
# sharing.write scopes. Held in memory for the run only; never logged.
DROPBOX_TOKEN=

# Fixed path in your Dropbox to overwrite each run. Defaults to /discount-statement.csv
DROPBOX_PATH=
