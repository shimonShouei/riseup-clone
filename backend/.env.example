# Copy to `.env` and fill in real values. NEVER commit `.env` (see .gitignore).
# This file contains PLACEHOLDERS ONLY — no real secrets.

# --- Auth (SECURITY.md R1/R7) ---
# Bearer token that gates POST /scrape. Generate a high-entropy value:
#   openssl rand -hex 32
# Must be >= 32 chars or the service refuses to start.
AUTH_TOKEN=replace-with-output-of-openssl-rand-hex-32

# --- Network (SECURITY.md R2) ---
# Interface to bind. Default 127.0.0.1 (loopback). For the private mesh, set to
# the WireGuard/Tailscale interface IP (e.g. 100.x.y.z). NEVER 0.0.0.0 on a host
# that has public connectivity.
BIND_HOST=127.0.0.1
PORT=8443

# --- TLS (SECURITY.md R3/R7) ---
# Paths to a cert + key you generate (see README "Generate a self-signed cert").
# Set BOTH or NEITHER. Leave empty only if TLS is terminated at a pinned proxy.
TLS_CERT_PATH=./certs/cert.pem
TLS_KEY_PATH=./certs/key.pem

# --- Logging (SECURITY.md R8/R9) ---
# Bodies/headers/credentials are NEVER logged regardless of level.
LOG_LEVEL=info

# --- Scraping ---
# Overall wall-clock budget (ms) for one scrape before it is aborted with a 504.
# Guards against a hung Chrome/bank session wedging the service. 1000..600000.
SCRAPE_TIMEOUT_MS=180000
