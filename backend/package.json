{
  "name": "riseup-backend",
  "version": "0.1.0",
  "description": "Hardened, stateless scrape-function backend for the RiseUp clone. Bank Discount scraping via israeli-bank-scrapers (headless Chrome), credentials in RAM only.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "5.10.0",
    "israeli-bank-scrapers": "6.8.0",
    "puppeteer": "24.43.1"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "3.2.7"
  }
}
